{
  "name": "@pasajero_0/agent-stack",
  "version": "0.1.0",
  "description": "CLI that deploys a Claude Code harness (hooks, subagents, skills, guards) onto your repo and manages MCP servers",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "agent-stack": "./bin/cli.mjs"
  },
  "files": [
    "dist",
    "bin",
    "mcp",
    "templates"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepare": "husky || true",
    "prepublishOnly": "pnpm build && pnpm typecheck && pnpm test"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "ai",
    "claude",
    "claude-code",
    "mcp",
    "hooks",
    "subagents",
    "agent",
    "cli"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  },
  "dependencies": {
    "@inquirer/prompts": "7.5.0",
    "chalk": "5.4.1",
    "commander": "13.1.0",
    "execa": "9.5.2",
    "ora": "8.2.0"
  },
  "devDependencies": {
    "@commitlint/cli": "20.5.0",
    "@commitlint/config-conventional": "20.5.0",
    "@types/node": "22.15.3",
    "husky": "9.1.7",
    "tsup": "8.4.0",
    "typescript": "5.8.3",
    "vitest": "3.1.2"
  }
}
